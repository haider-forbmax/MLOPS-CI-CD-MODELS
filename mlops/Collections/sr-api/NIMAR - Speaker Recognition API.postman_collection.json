		{
			"name": "Add Speaker",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer 123",
						"type": "text"
					},
					{
						"key": "Content-Type",
						"value": "multipart/form-data",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "audio_file",
							"description": "Audio or video file for adding speaker",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "https://sr-api-dgx.nimar.gov.pk/v1/add_speaker?person_label=speaker_name",
					"protocol": "https",
					"host": [
						"sr-api-dgx",
						"nimar",
						"gov",
						"pk"
					],
					"path": [
						"v1",
						"add_speaker"
					],
					"query": [
						{
							"key": "person_label",
							"value": "speaker_name",
							"description": "Label/name for the speaker to add"
						}
					]
				},
				"description": "Endpoint to add a new speaker using an audio or video file. Validates that the file has a non-silent audio track."
			},
			"response": []
		},
