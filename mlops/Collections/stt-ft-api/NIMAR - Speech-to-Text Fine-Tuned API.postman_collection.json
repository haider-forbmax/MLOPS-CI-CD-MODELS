			"item": [
				{
					"name": "Transcribe Video/Audio",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"type": "text"
							},
							{
								"key": "X-Language",
								"value": "urdu",
								"description": "Language code (english for English)",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "video_file",
									"description": "Video or audio file to transcribe",
									"type": "file",
									"src": "/home/nouman/Downloads/IQera Schools ｜ Artificial Intelligence ｜ Online Academy.mp4"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/v1/transcribe",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"v1",
								"transcribe"
							]
						},
						"description": "Transcribe video or audio file to text with timestamps"
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "POST",
								"header": [
									{
										"key": "X-API-Key",
										"value": "{{api_key}}"
									},
									{
										"key": "X-Language",
										"value": "ur"
									}
								],
								"body": {
