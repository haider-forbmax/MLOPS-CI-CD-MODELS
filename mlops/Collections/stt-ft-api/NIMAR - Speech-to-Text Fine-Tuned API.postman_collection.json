									"raw": "{{base_url}}/v1/transcribe",
									"host": [
										"{{base_url}}"
									],
									"path": [
										"v1",
										"transcribe"
									]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [
