# Triton Inference Server Configuration
TRITON_SERVER_URL=192.168.18.48:8000
TRITON_MODEL_NAME=yolo5-ticker-flasher
# Model Input/Output Names (Based on YOLO11 model config)
MODEL_INPUT_NAME=images
MODEL_OUTPUT_NAME=output0

# Model Dimensions (Based on YOLO11 model config)
