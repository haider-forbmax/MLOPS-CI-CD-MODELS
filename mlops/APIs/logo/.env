# Triton Inference Server Configuration
# TRITON_SERVER_URL=yolo11-logo.models-inference.local
# TRITON_SERVER_URL=192.168.18.22:30483
TRITON_SERVER_URL=192.168.18.30:3087
TRITON_MODEL_NAME=onnx
# Model Input/Output Names (Based on YOLO11 model config)
MODEL_INPUT_NAME=images
MODEL_OUTPUT_NAME=output0

# Model Dimensions (Based on YOLO11 model config)
# Input: [batch_size, channels, height, width] = [N, 3, -1, -1] (dynamic height/width)
MODEL_INPUT_DIMS=[3, -1, -1]
# Output: [84, -1] means [classes+coords, num_detections] for YOLO11
# MODEL_OUTPUT_DIMS=[84, -1]
MODEL_OUTPUT_DIMS=[-1, -1]

# Default processing parameters for YOLO11
DEFAULT_INPUT_SIZE=[640, 640]
DEFAULT_CONFIDENCE_THRESHOLD=0.25
DEFAULT_NMS_THRESHOLD=0.45

# YOLOv11n Logo Classes (40 classes total)
#CLASSES={"0": "24news", "1": "92news", "2": "aajnews", "3": "abbtakk", "4": "abnnews", "5": "ajktelevision", "6": "ary", "7": "bol", "8": "capitaltvnews", "9": "cda", "10": "dawn", "11": "dunyanews", "12": "election commission of pakistan", "13": "express", "14": "fbr", "15": "geo", "16": "gnnnews", "17": "gtvnews", "18": "hum", "19": "mashriqnews", "20": "ministry of foreign affairs", "21": "ministry of human rights", "22": "nab", "23": "neonews", "24": "nepra", "25": "onenews", "26": "pemra", "27": "pta", "28": "ptcl", "29": "ptv", "30": "ptvglobal", "31": "ptvhome", "32": "ptvnational", "33": "ptvparliment", "34": "ptvsports", "35": "ptvworld", "36": "publicnews", "37": "rozenews", "38": "samaa", "39": "suchnews"}


# Image Processing Limits       
MAX_IMAGE_SIZE=10485760  # 10MB in bytes
SUPPORTED_FORMATS=jpeg,png,jpg,webp

# API Configuration
API_HOST=0.0.0.0
API_PORT=9002

# Timeouts (in seconds)
REQUEST_TIMEOUT=30
TRITON_TIMEOUT=10

# YOLO11 Specific Settings
TASK_TYPE=detect

# Logging Configuration
LOG_LEVEL=DEBUG

API_KEY=123